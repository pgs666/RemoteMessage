<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Switch
            android:id="@+id/switchEnableLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_enable_log" />

        <Switch
            android:id="@+id/switchAutoClearLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_auto_clear_log" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editAutoClearMinutes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_auto_clear_minutes"
                android:inputType="number" />

            <Button
                android:id="@+id/btnSaveAutoClear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/btn_save_auto_clear" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPauseLogRefresh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_pause_log_refresh" />

            <Button
                android:id="@+id/btnCopyLog"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/btn_copy_log" />

            <Button
                android:id="@+id/btnClearLogNow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/btn_clear_log_now" />
        </LinearLayout>

        <TextView
            android:id="@+id/textLogContent"
            android:layout_width="match_parent"
            android:layout_height="560dp"
            android:layout_marginTop="12dp"
            android:background="#11000000"
            android:padding="8dp"
            android:text="@string/status_debug_log_empty"
            android:textIsSelectable="true" />
    </LinearLayout>

</ScrollView>
